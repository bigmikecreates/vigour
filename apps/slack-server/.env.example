# ── Slack (Phase 1 — Socket Mode local dev) ────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
PORT=3001

# ── Slack OAuth (user token flow) ──────────────────────────────────────
# From api.slack.com/apps → Basic Information → App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# For local dev. Change to your public URL in production.
SLACK_OAUTH_REDIRECT_URI=http://localhost:3001/slack/oauth/callback

# ── LLM "mind" (Phase 2) ───────────────────────────────────────────────
# Pick the primary provider; optional comma-separated fallbacks tried in order.
# Put a free/local provider first to minimise spend.
VIGOUR_LLM_PROVIDER=ollama
VIGOUR_LLM_FALLBACKS=deepseek

# Provider credentials (only the ones you use are needed)
# Local — no key required, just run `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434/v1
# Cheap hosted
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=          # Kimi
# Free-tier aggregators
OPENROUTER_API_KEY=
GROQ_API_KEY=
# Paid baselines
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (defaults live in packages/llm/presets.ts)
# VIGOUR_OLLAMA_MODEL=llama3.1
# VIGOUR_DEEPSEEK_MODEL=deepseek-v4-flash
# VIGOUR_KIMI_MODEL=kimi-k2.6
# VIGOUR_OPENROUTER_MODEL=deepseek/deepseek-chat-v3:free
# VIGOUR_GROQ_MODEL=llama-3.3-70b-versatile
# VIGOUR_CLAUDE_MODEL=claude-haiku-4-5

# ── Infra ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vigour:vigour@localhost:5432/vigour
REDIS_URL=redis://localhost:6379
