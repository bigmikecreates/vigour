{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.schema/config.schema.json",
  "productName": "Vigour",
  "version": "0.1.0",
  "identifier": "com.vigour.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vigour",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "skipTaskbar": true,
        "resizable": false,
        "width": 400,
        "height": 600,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
