# OpenWakeWord model name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy, ok_nabu)
# or path to a custom .onnx file — models are downloaded from HuggingFace on first run
VIGOUR_WAKE_WORD_MODEL=hey_jarvis
VIGOUR_WAKE_WORD_THRESHOLD=0.5

# Whisper model: tiny, base, small, medium, large-v3
VIGOUR_WHISPER_MODEL=base
VIGOUR_WHISPER_DEVICE=cpu
VIGOUR_WHISPER_COMPUTE=int8_float32

# Kokoro TTS voice (af_heart, af_bella, am_adam, am_michael, bf_emma, bm_george, ...)
VIGOUR_KOKORO_VOICE=af_heart
VIGOUR_KOKORO_SPEED=1.0

# Audio
VIGOUR_SAMPLE_RATE=16000
VIGOUR_CHUNK_MS=30
VIGOUR_SILENCE_MS=500

# IPC
VIGOUR_MCP_URL=http://localhost:3002
VIGOUR_WS_URL=ws://127.0.0.1:9000

# Auth (future)
VIGOUR_AUTH_ENABLED=false
