# Porcupine access key (free from picovoice.ai)
VIGOUR_PORCUPINE_KEY=
# Built-in keyword or path to .ppn file
VIGOUR_WAKE_WORD=computer
VIGOUR_SENSITIVITY=0.5

# Whisper model: tiny, base, small, medium, large-v3
VIGOUR_WHISPER_MODEL=base
VIGOUR_WHISPER_DEVICE=cpu
VIGOUR_WHISPER_COMPUTE=int8_float32

# Piper voice model name (auto-downloaded)
VIGOUR_PIPER_MODEL=en_US-lessac-medium
VIGOUR_PIPER_RATE=1.0

# Audio
VIGOUR_SAMPLE_RATE=16000
VIGOUR_CHUNK_MS=30
VIGOUR_SILENCE_MS=500

# IPC
VIGOUR_MCP_URL=http://localhost:3002
VIGOUR_WS_URL=ws://127.0.0.1:9000

# Auth (future)
VIGOUR_AUTH_ENABLED=false
